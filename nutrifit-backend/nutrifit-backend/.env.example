# ── Server
PORT=5000
NODE_ENV=development

# ── MongoDB
MONGO_URI=mongodb://localhost:27017/nutrifit
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nutrifit

# ── JWT
JWT_SECRET=nutrifit_super_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ── Anthropic (for AI Dietitian chat)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Python AI Module (optional)
AI_MODULE_URL=http://localhost:8000

# ── Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# ── Logging
LOG_LEVEL=info
